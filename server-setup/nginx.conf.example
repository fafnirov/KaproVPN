# Path-based KaproTUN binary mirror.
#
# Paste this `location` block INTO the existing kaprovpn.pro server block
# (the :443 vhost certbot already manages for the website). No new
# subdomain / DNS / cert needed — the mirror rides the kaprovpn.pro vhost
# that's already live.
#
# The client requests  https://kaprovpn.pro/files/<asset>  — see
# KAPROTUN_MIRROR_BASE in xray_installer / hysteria_installer /
# updater_dialog. sync-binaries.sh drops the files into
# /var/www/kaprovpn.pro/files (MIRROR_DIR); keep `alias` below in sync.

location /files/ {
    alias /var/www/kaprovpn.pro/files/;    # must match MIRROR_DIR in sync-binaries.sh
    autoindex off;                          # don't expose the directory listing

    types {
        application/zip          zip;
        application/x-msdownload exe;
        application/octet-stream dll;
    }

    # Assets change weekly at most — cache hard.
    location ~* \.(zip|exe|dll)$ {
        expires 1d;
        add_header Cache-Control "public, immutable";
        add_header X-Content-Type-Options "nosniff";
    }
}

# After pasting into the kaprovpn.pro server block:
#   sudo nginx -t && sudo systemctl reload nginx
# Verify:
#   curl -sI https://kaprovpn.pro/files/Xray-windows-64.zip   # -> 200
