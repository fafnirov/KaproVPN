<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Сеть — для запуска Xray и загрузки подписок -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service для долгоживущего VPN-туннеля -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Уведомления (Android 13+) — foreground service не запустится без них -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot receiver — для «Автоподключение при запуске» на boot устройства -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- QR-сканер на ConfigsScreen → ScanQrScreen. Runtime permission
         запрашивается в Compose через rememberLauncherForActivityResult.
         required=false — устройства без камеры (Android TV, кастомные
         сборки) всё равно ставят APK, на ScanQrScreen упадут в graceful
         fallback с подсказкой «вставь URL вручную». -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:name=".App"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.KaproVPN"
        android:supportsRtl="true"
        android:allowBackup="false"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.KaproVPN">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".vpn.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Quick Settings tile — пользователь добавляет её через системный
             UI шторки (edit tiles → drag KaproVPN). После этого один тап
             toggle'ит VPN. -->
        <service
            android:name=".vpn.VpnTileService"
            android:exported="true"
            android:icon="@drawable/tile_idle"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

        <service
            android:name=".vpn.KaproVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <!-- Android 14+ требует объявить причину для специальных foreground-сервисов.
                 "vpn_tunnel" — описание для Play Console review (мы не публикуемся
                 в Play, но AGP всё равно требует поле). -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_tunnel — System-wide VPN routing via Xray-core" />
        </service>
    </application>
</manifest>
