# Скопируй этот файл в `keystore.properties` (gitignored) и заполни
# пути / пароли. После этого `./gradlew :app:assembleRelease` соберёт
# подписанный release APK.
#
# Сгенерировать keystore (один раз):
#   keytool -genkey -v \
#     -keystore kaprovpn-release.jks \
#     -keyalg RSA -keysize 4096 -validity 10000 \
#     -alias kaprovpn
#
# Сохрани .jks в надёжном месте — без него ты не сможешь выпускать
# апдейты приложения (Android требует тот же signature для install
# поверх предыдущей версии).

storeFile=kaprovpn-release.jks
storePassword=ЗАМЕНИ-ЭТО
keyAlias=kaprovpn
keyPassword=ЗАМЕНИ-ЭТО
